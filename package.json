{
  "name": "grpc-socket-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Simple production-ready gateway between gRPC services and Socket.IO clients.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rimraf dist src/types/generated src/schemas/generated src/grpc/registry.ts",
    "generate": "tsx scripts/generate.ts",
    "build": "npm run generate && tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.1",
    "@grpc/proto-loader": "^0.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "mysql2": "^3.22.5",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "protobufjs": "^7.5.4",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.30",
    "zod": "^4.1.5",
    "zod-to-ts": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0"
  }
}
