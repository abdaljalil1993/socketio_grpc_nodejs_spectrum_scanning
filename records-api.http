@baseUrl = http://localhost:3000
@multipartBoundary = NewSpecBoundary

### Create signal record with IQ file upload
# @name createSignalRecord
POST {{baseUrl}}/records
Content-Type: multipart/form-data; boundary={{multipartBoundary}}

--{{multipartBoundary}}
