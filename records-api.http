Content-Disposition: form-data; name="iqFile"; filename="capture_001.iq"
Content-Type: application/octet-stream

< ./docs/fixtures/capture_001.iq
--{{multipartBoundary}}--

### Get all signal records
GET {{baseUrl}}/records

### Get the created signal record by UUID
GET {{baseUrl}}/records/{{createSignalRecord.response.body.record.uuid}}

### Download the SigMF data file only
GET {{baseUrl}}/records/{{createSignalRecord.response.body.record.uuid}}/sigmf-data
Accept: application/octet-stream

### Download the SigMF metadata file only
GET {{baseUrl}}/records/{{createSignalRecord.response.body.record.uuid}}/sigmf-meta
Accept: application/json

### Download the SigMF ZIP archive containing both .sigmf-data and .sigmf-meta files
GET {{baseUrl}}/records/{{createSignalRecord.response.body.record.uuid}}/sigmf
Accept: application/zip